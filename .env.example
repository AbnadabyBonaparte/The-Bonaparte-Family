# The Bonaparte Family - Environment Variables

# Application
NODE_ENV=production
PORT=3000

# Site Configuration
VITE_SITE_URL=https://thebonapartefamily.com
VITE_SITE_NAME="The Bonaparte Family"
VITE_SITE_DESCRIPTION="Real life. Road. Land. Education. Health. Faith. Business. Legacy."

# Supabase — Journal Bonaparte
# The anon key can only READ the journal. Publishing at /escrever requires a
# real Supabase Auth user (email/password) — writes are enforced server-side by
# Row Level Security (see supabase/journal_rls.sql). There is no bundled password.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: Analytics (for future)
# VITE_ANALYTICS_ENDPOINT=
# VITE_ANALYTICS_WEBSITE_ID=

# Optional: Newsletter/Email
# VITE_NEWSLETTER_API_KEY=
